    {
      "datasource": "PBFA97CFB590B2093",
      "description": "Health of the BigPeer-to-BigPeer replication link over the last 30 days.\n\nConnection: Whether a replication session is currently active between the two BigPeers.\nLatency: % of data sync cycles completing within 30 seconds.\nIntegration: % of updates received from the remote peer that were applied without error.\nSession Health: % of replication messages exchanged without a connection-breaking error.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 2,
          "mappings": [],
          "max": 100,
          "min": 80,
          "noValue": "No data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "#FF9830", "value": 85},
              {"color": "green", "value": 95}
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Connection"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0":   {"text": "Disconnected", "color": "red",   "index": 0},
                      "100": {"text": "Connected",    "color": "green", "index": 1}
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32},
      "id": 6,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": "PBFA97CFB590B2093",
          "expr": "clamp_max(max(hydra_subscription_connected_clients{namespace=\"$namespace\",k8s_container_name=\"replication-server\"}) * 100, 100)",
          "legendFormat": "Connection",
          "refId": "A"
        },
        {
          "datasource": "PBFA97CFB590B2093",
          "expr": "(1 - ((sum(rate(ditto_replication_outgoing_cycle_duration_count{namespace=\"$namespace\"}[30d])) - sum(rate(ditto_replication_outgoing_cycle_duration_bucket{namespace=\"$namespace\",le=\"32.768\"}[30d]))) / clamp_min(sum(rate(ditto_replication_outgoing_cycle_duration_count{namespace=\"$namespace\"}[30d])), 0.000000001))) * 100",
          "legendFormat": "Latency",
          "refId": "B"
        },
        {
          "datasource": "PBFA97CFB590B2093",
          "expr": "(1 - ((sum(rate(ditto_replication_update_integration_outcomes_total{namespace=\"$namespace\",outcome=~\"error.*\"}[30d])) or vector(0)) / clamp_min(sum(rate(ditto_replication_update_integration_outcomes_total{namespace=\"$namespace\",outcome=~\".+\"}[30d])), 0.000000001))) * 100",
          "legendFormat": "Integration",
          "refId": "C"
        },
        {
          "datasource": "PBFA97CFB590B2093",
          "expr": "(1 - (((sum(rate(ditto_replication_session_errors_recv_total{namespace=\"$namespace\"}[30d])) or vector(0)) + (sum(rate(ditto_replication_session_errors_send_total{namespace=\"$namespace\"}[30d])) or vector(0))) / clamp_min(sum(rate(ditto_replication_messages_received_total{namespace=\"$namespace\"}[30d])) + sum(rate(ditto_replication_messages_sent_total{namespace=\"$namespace\"}[30d])), 0.000000001))) * 100",
          "legendFormat": "Session Health",
          "refId": "D"
        }
      ],
      "title": "BigPeer to BigPeer Replication",
      "type": "gauge"
    }
