        {
          "datasource": "PBFA97CFB590B2093",
          "expr": "(1 - ((sum(rate(hydra_store_actix_http_requests_duration_secs_count{namespace=\"$namespace\",exported_endpoint!~\"/health.*|/metrics|/cluster_version\",status_code=~\"[45]xx\"}[30d])) or vector(0)) / clamp_min(sum(rate(hydra_store_actix_http_requests_duration_secs_count{namespace=\"$namespace\",exported_endpoint!~\"/health.*|/metrics|/cluster_version\",status_code=~\"[2-5]xx\"}[30d])), 0.000000001))) * 100",
