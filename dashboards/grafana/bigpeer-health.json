    {
      "datasource": "PBFA97CFB590B2093",
      "description": "Freshness is a measure of the latency between an event being generated and it becoming available for consumption.\n\nFreshness score per Kafka consumer: 100 - (lag / 500), clamped to [0, 100]. Green: lag < 2 500 msgs, Amber: lag < 7 500 msgs. Store Replica and CDC Transformer consume transaction.log; MongoDB Connector consumes the CDC output topic (ditto namespace only).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 2,
          "mappings": [],
          "max": 100,
          "min": 80,
          "noValue": "No data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "#FF9830", "value": 85},
              {"color": "green", "value": 95}
            ]
